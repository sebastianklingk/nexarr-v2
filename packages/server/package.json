{
  "name": "@nexarr/server",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "NODE_OPTIONS='--experimental-sqlite' tsx watch --ignore '../client/**' --ignore '../shared/**' --ignore '../../.ai/**' --ignore '../../node_modules/**' src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "NODE_OPTIONS='--experimental-sqlite' node dist/server.js"
  },
  "dependencies": {
    "@nexarr/shared": "*",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "express-session": "^1.18.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
